{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.vss_fire": {
			"initial_state": "setup",
			"states": {
				"setup": {
					"transitions": [
						{"fire": "query.property('gun:fire') == 1"}
					]
				},
				"fire": {
					"animations": [
						{"vss_shoot": "v.vss"}
					],
					"transitions": [
						{
						  "fire": "query.property('gun:fire') == 1"
						}
					]
				}
			}
		},
		"controller.animation.vss_sneak": {
			"initial_state": "setup",
			"states": {
				"setup": {
					"transitions": [
						{"hold": "variable.vss"}
					]
				},
				"hold": {
					"animations": [
						{"vss_sneak": "v.vss"}
					],
					"transitions": [
						{"reload": "q.property('addon:gun') == 2"},
						{"reload2": "q.property('addon:gun') == 3"},
                        {"moving": "query.is_riding && query.ground_speed > 0.0"}
					],
					"blend_transition": 0.1
				},
                "moving": {
                    "animations": [
                        {"crawl2": "v.vss"}
                    ],
                    "blend_transition": 0.1,
                    "blend_via_shortest_path": true,
                    "transitions": [
                        {
                            "hold": "query.is_riding && query.ground_speed == 0.0"
                        },
                        {
                            "default": "!query.is_riding"
                        }
                    ]
                },
				"reload": {
					"animations": [
						{"vss_reload_sneak": "v.vss"}
					],
					"transitions": [
						{"hold": "q.all_animations_finished"},
						{"hold": "q.property('addon:gun') != 2"}
					]
				},
				"reload2": {
					"animations": [
						{"vss_reload2_sneak": "v.vss"}
					],
					"transitions": [
						{"hold": "q.all_animations_finished"},
						{"hold": "q.property('addon:gun') != 3"}
					]
				}
			}
		},
		"controller.animation.vss_third": {
			"initial_state": "setup",
			"states": {
				"setup": {
					"transitions": [
						{"hold": "variable.vss"}
					]
				},
				"hold": {
					"animations": [
						{"vss_third": "v.vss"}
					],
					"transitions": [
						{"reload": "q.property('addon:gun') == 2"},
						{"aim": "q.is_sneaking"},
						{"sprint": "q.is_sprinting && !q.is_using_item"},
						{"reload2": "q.property('addon:gun') == 3"}
					],
					"blend_transition": 0.1
				},
				"reload": {
					"animations": [
						{"vss_reload_third": "v.vss"}
					],
					"transitions": [
						{"hold": "q.all_animations_finished"},
						{"hold": "q.property('addon:gun') != 2"}
					]
				},
				"reload2": {
					"animations": [
						{"vss_reload2_third": "v.vss"}
					],
					"transitions": [
						{"hold": "q.all_animations_finished"},
						{"hold": "q.property('addon:gun') != 3"}
					]
				},
				"aim": {
					"animations": [
						{"vss_aim_third": "v.vss"}
					],
					"transitions": [
						{"hold": "!q.is_sneaking"},
						{"reload": "q.property('addon:gun') == 2"},
						{"reload2": "q.property('addon:gun') == 3"}
					],
					"blend_transition": 0.1
				},
				"sprint": {
					"animations": [
						{"vss_sprint_third": "v.vss"}
					],
					"transitions": [
						{"hold": "!q.is_sprinting"},
						{"hold": "q.is_using_item"},
						{"reload": "q.property('addon:gun') == 2"},
						{"reload2": "q.property('addon:gun') == 3"}
					],
					"blend_transition": 0.2
				}
			}
		},
		"controller.animation.vss": {
			"initial_state": "setup",
			"states": {
				"setup": {
					"transitions": [
						{"hold": "variable.vss"}
					]
				},
				"hold": {
					"animations": [
						{"vss": "v.vss"}
					],
					"transitions": [
						{"reload": "q.property('addon:gun') == 2"},
						{"aim": "q.is_sneaking"},
						{"sprint": "q.is_sprinting && !q.is_using_item"},
						{"reload2": "q.property('addon:gun') == 3"}
					],
					"blend_transition": 0.1
				},
				"reload": {
					"animations": [
						{"vss_reload": "v.vss"}
					],
					"transitions": [
						{"hold": "q.all_animations_finished"},
						{"hold": "q.property('addon:gun') != 2"}
					]
				},
				"reload2": {
					"animations": [
						{"vss_reload2": "v.vss"}
					],
					"transitions": [
						{"hold": "q.all_animations_finished"},
						{"hold": "q.property('addon:gun') != 3"}
					]
				},
				"aim": {
					"animations": [
						{"vss_aim": "v.vss"}
					],
					"transitions": [
						{"hold": "!q.is_sneaking"},
						{"reload": "q.property('addon:gun') == 2"},
						{"reload2": "q.property('addon:gun') == 3"}
					],
					"blend_transition": 0.1
				},
				"sprint": {
					"animations": [
						{"vss_sprint": "v.vss"}
					],
					"transitions": [
						{"hold": "!q.is_sprinting"},
						{"hold": "q.is_using_item"},
						{"reload": "q.property('addon:gun') == 2"},
						{"reload2": "q.property('addon:gun') == 3"}
					],
					"blend_transition": 0.2
				}
			}
		}
	}
}