{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.m67": {
      "initial_state": "setup",
      "states": {
        "setup": {
          "animations": [
              "m67"
          ],
          "transitions": [
            {
              "m67_use": "q.is_using_item"
            }]
        },
        "m67_use": {
          "animations": [
              "m67_use"
          ],
          "blend_transition": 0.1,
          "transitions": [
            {
              "setup": "!q.is_using_item && !q.any_animation_finished"
            },
            {
              "m67_unuse": "!q.is_using_item && q.any_animation_finished"
            }
          ]
        },
        "m67_unuse": {
          "animations": [
              "m67_unuse"
          ],
          "transitions": [
            {
              "setup": "q.any_animation_finished"
            }
          ]
        }
      }
    },
    "controller.animation.m67_third": {
      "initial_state": "setup",
      "states": {
        "setup": {
          "animations": [
              "m67_third"
          ],
          "transitions": [
            {
                "idle": "query.is_riding && query.mark_variant == 1"
            },
            {
                "moving": "query.is_riding && query.mark_variant == 2"
            },
            {
              "m67_use": "q.is_using_item || c.is_using_item"
            }]
        },
        "m67_use": {
          "animations": [
              "m67_use_third"
          ],
          "transitions": [
            {
              "m67_unuse": "!q.is_using_item || !c.is_using_item"
            }
          ]
        },
        "m67_unuse": {
          "animations": [
              "m67_unuse_third"
          ],
          "transitions": [
            {
              "setup": "q.any_animation_finished"
            }
          ]
        },
        "idle": {
            "animations": [
                "crawl1"
            ],
            "transitions": [
                {
                    "moving": "query.ground_speed > 0.0 && query.is_riding"
                },
                {
                    "setup": "!query.is_riding"
                }
            ],
            "blend_transition": 0.1,
            "blend_via_shortest_path": true
        },
        "moving": {
            "animations": [
                "crawl2"
            ],
            "blend_transition": 0.1,
            "blend_via_shortest_path": true,
            "transitions": [
                {
                    "idle": "query.ground_speed == 0.0 && query.is_riding"
                },
                {
                    "setup": "!query.is_riding"
                }
            ]
        }
      }
    }
  }
}