{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.crawl": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        {
                            "idle": "query.is_riding && query.mark_variant == 1"
                        },
                        {
                            "moving": "query.is_riding && query.mark_variant == 1 && query.ground_speed > 0.0"
                        }
                    ],
                    "blend_transition": 0.1,
                    "blend_via_shortest_path": true
                },
                "idle": {
                    "animations": [
                        "crawl1"
                    ],
                    "transitions": [
                        {
                            "moving": "query.ground_speed > 0.0 && query.is_riding"
                        },
                        {
                            "default": "!query.is_riding"
                        }
                    ],
                    "blend_transition": 0.1,
                    "blend_via_shortest_path": true
                },
                "moving": {
                    "animations": [
                        "crawl2"
                    ],
                    "blend_transition": 0.1,
                    "blend_via_shortest_path": true,
                    "transitions": [
                        {
                            "idle": "query.ground_speed == 0.0 && query.is_riding"
                        },
                        {
                            "default": "!query.is_riding"
                        }
                    ]
                }
            }
        }
    }
}