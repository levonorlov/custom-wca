{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "addon:vehicle_babah_dim",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "textures/particle/campfire_smoke"
			}
		},
		"components": {
			"minecraft:emitter_rate_instant": {
				"num_particles": 50
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1
			},
			"minecraft:emitter_shape_sphere": {
				"radius": 3,
				"direction": ["Math.random(-2, 2)", 20, "Math.random(-2, 2)"]
			},
			"minecraft:particle_initialization": {
				"per_render_expression": "v.size=1.6*math.pow(1-(v.particle_age/v.particle_lifetime),0.08);"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 35
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random(0,360)",
				"rotation_rate": 20
			},
			"minecraft:particle_initial_speed": 1,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [5, 7, 0],
				"linear_drag_coefficient": 20
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["v.size", "v.size"],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 1,
					"texture_height": 12,
					"flipbook": {
						"base_UV": [0, 2],
						"size_UV": [1, 1],
						"step_UV": [0, 1],
						"frames_per_second": 1
					}
				}
			},
			"minecraft:particle_appearance_lighting": {},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#4A999999",
						"1.0": "#1FC9C9C9"
					}
				}
			}
		}
	}
}