{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "addon:vog_dim2",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "textures/particle/campfire_smoke"
			}
		},
		"components": {
			"minecraft:emitter_rate_instant": {
				"num_particles": 10
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 0.2
			},
			"minecraft:emitter_shape_sphere": {
				"radius": 1.5,
				"direction": ["Math.random(-5, 5)", 1, "Math.random(-5, 5)"]
			},
			"minecraft:particle_initialization": {
				"per_render_expression": "v.size=1.2*math.pow(1-(v.particle_age/v.particle_lifetime),0.08);"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 15
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random(0,360)",
				"rotation_rate": 20
			},
			"minecraft:particle_initial_speed": 1,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [10, 5, 0],
				"linear_drag_coefficient": 15
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["v.size", "v.size"],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 1,
					"texture_height": 12,
					"flipbook": {
						"base_UV": [0, 2],
						"size_UV": [1, 1],
						"step_UV": [0, 1],
						"frames_per_second": 1
					}
				}
			},
			"minecraft:particle_appearance_lighting": {},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#4AD9D9D9",
						"1.0": "#1FE3E3E3"
					}
				}
			}
		}
	}
}