          ],
          "part_visibility": [
            { "*": true },
            { "head": "!q.has_rider" },
            { "anteni": "!q.has_rider" },
            { "krishka": "!q.has_rider" },
            { "pushka": "!q.has_rider" },
            { "2a42": "!q.has_rider" },
            { "2a72": "!q.has_rider" },
            { "gilza_bmp3": "!q.has_rider" },
            { "gilza_2a72": "!q.has_rider" }
          ],
          "is_hurt_color": {},
          "on_fire_color": {}
        },
	"controller.render.bmp2d": {
      "textures": ["Texture.default"],
      "geometry": "Geometry.default",
