    "controller.render.flash": {
       "geometry": "Geometry.flash",
       "materials": [ { "*": "Material.flash" } ],
       "textures": [ "Texture.flash" ],
       "uv_anim": {
         "offset": [
           0.0,
           "math.mod(math.floor(query.life_time * 10),6) / 6"
         ],
         "scale": [
           1.0,
           "1 / 6"
         ]
       },
       "part_visibility": [
         { "*": true },
         { "flash_100mm": "q.is_riding && !query.mark_variant == 1 && !query.mark_variant == 2" },
         { "flash_2a72": "q.is_riding && !query.mark_variant == 1 && !query.mark_variant == 2" },
         { "flash_mg": "variable.fnmag || variable.pkm || variable.pkp || variable.pkp_zenit" },
         { "flash_tigr_m_kord": "variable.tigr_m_kord" },
         { "flash_m1151_m2hb": "variable.m1151_m2hb" },
         { "flash": "variable.guns && !variable.rgd5 && !variable.m67 && !variable.fnmag && !variable.rpg7 && !variable.rpoa && !variable.m72 && !variable.pkm && !variable.pkp && !variable.pkp_zenit && !q.equipped_item_any_tag('slot.weapon.mainhand','reload') && !q.equipped_item_any_tag('slot.weapon.mainhand','pbs') && !q.equipped_item_any_tag('slot.weapon.mainhand','pbs1') && !variable.hexagon && !variable.asval && !variable.asvalm" }
       ]
      },
