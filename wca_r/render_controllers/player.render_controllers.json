{
  "format_version": "1.8.0",
  "render_controllers": {
    "controller.render.player.first_person": {
      "is_hurt_color": {},
      "on_fire_color": {},
      "geometry": "Geometry.default",
      "materials": [ { "*": "Material.default" } ],
      "textures": [ "Texture.default" ],
      "part_visibility": [
        { "ssh68": false },
        { "*": false },
        { "rightArm": "query.get_equipped_item_name(0, 1) == '' || query.get_equipped_item_name(0, 1) == 'map' || variable.guns || variable.f1 || variable.ai1m || variable.zhgut || variable.knifes" },
        { "rightSleeve": "query.get_equipped_item_name(0, 1) == '' || query.get_equipped_item_name(0, 1) == 'map' || variable.guns || variable.f1 || variable.ai1m || variable.zhgut || variable.knifes && !v.armor" },
        { "leftArm": "(query.get_equipped_item_name(0, 1) == 'map' && query.get_equipped_item_name('off_hand') != 'shield') || (query.get_equipped_item_name('off_hand') == 'map' && !query.item_is_charged) || (!query.item_is_charged && (variable.item_use_normalized > 0 && variable.item_use_normalized < 1.0)) || (variable.guns) || (variable.f1) || (variable.ai1m) || (variable.zhgut) || (variable.knifes)" },
        { "leftSleeve": "query.get_equipped_item_name(0, 1) == 'map' && query.get_equipped_item_name('off_hand') != 'shield' || (query.get_equipped_item_name('off_hand') == 'map' && !query.item_is_charged) || (!query.item_is_charged && (variable.item_use_normalized > 0 && variable.item_use_normalized < 1.0)) || (variable.guns) || (variable.f1) || (variable.ai1m) || (variable.zhgut) || (variable.knifes) && !v.armor" }
      ]
    },
    "controller.render.player.third_person": {
      "geometry": "Geometry.default",
      "materials": [ { "*": "Material.default" } ],
      "textures": [ "Texture.default" ],
      "is_hurt_color": {},
      "on_fire_color": {},
      "part_visibility": [
        { "*": true },
        { "hat": "!q.equipped_item_any_tag('slot.armor.head','balaklava') && !q.is_item_name_any('slot.inventory',0,'addon:balaklava') && !q.is_item_name_any('slot.inventory',0,'addon:balaklava2')" },
        { "jacket": "!v.armor" },
        { "rightSleeve": "!v.armor" },
        { "leftSleeve": "!v.armor" },
        { "rightPants": "!v.armor" },
        { "leftPants": "!v.armor" },
        { "helmet": "variable.helmet_layer_visible" },
        { "leftLegging": "variable.leg_layer_visible" },
        { "rightLegging": "variable.leg_layer_visible" },
        { "leftBoot": "variable.boot_layer_visible" },
        { "rightBoot": "variable.boot_layer_visible" },
        { "leftSock": "variable.boot_layer_visible && variable.leg_layer_visible" },
        { "rightSock": "variable.boot_layer_visible && variable.leg_layer_visible" },
        { "bodyArmor": "variable.chest_layer_visible && !query.has_cape" },
        { "leftArmArmor": "variable.chest_layer_visible && !query.has_cape" },
        { "rightArmArmor": "variable.chest_layer_visible && !query.has_cape" },
        { "belt": "variable.chest_layer_visible && variable.leg_layer_visible" }
      ]
    },
    "controller.render.player.map": {
      "geometry": "Geometry.default",
      "materials": [ { "*": "Material.default" } ],
      "textures": [ "Texture.default" ],
      "part_visibility": [
        { "*": false },
        { "head": true },
        { "hat": true },
        { "helmet": true }
      ]
    }
  }
}
