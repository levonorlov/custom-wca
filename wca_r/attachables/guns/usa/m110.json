
{
  "format_version": "1.10.0",
  "minecraft:attachable": {
    "description": {
      "identifier": "addon:m110",
      "materials": {
        "default": "slime_outer",
        "gun": "entity_alphatest"
      },
      "textures": {
        "default": "textures/guns/nato/m110"
      },
      "geometry": {
        "default":  "geometry.m110"
      },
      "scripts": {
        "pre_animation": [
           "v.main_hand = c.item_slot == 'main_hand';",
           "v.m110 = c.item_slot == 'main_hand';",
           "v.fire = q.main_hand_item_use_duration > 0.0f;"
        ],
        "animate": [
          {"m110_controller": "c.is_first_person && !q.is_riding"},
          {"m110_fire_controller": "variable.m110"},
          {"m110_controller_sneak": "!c.is_first_person && query.is_riding"}

        ]
      },
      "animations": {
        "m110_aim": "animation.m110_aim",
        "m110_controller": "controller.animation.m110",
        "m110_controller_sneak": "controller.animation.m110_sneak",
        "m110_sneak": "animation.m110_sneak",
        "m110_reload_sneak": "animation.m110_reload_sneak",
        "m110_reload2_sneak": "animation.m110_reload2_sneak",
        "m110_fire_controller": "controller.animation.m110_fire",
        "m110_shoot": "animation.m110_shoot",
        "m110_reload": "animation.m110_reload_item",
        "m110_reload2": "animation.m110_reload2"
      },
      "render_controllers": [ 
				{ "controller.render.gun": "!c.is_first_person || c.is_first_person && !q.is_sneaking" },
				{ "controller.render.crossbow": "c.is_first_person && !q.is_riding && q.is_sneaking" } ]
    }
  }
}