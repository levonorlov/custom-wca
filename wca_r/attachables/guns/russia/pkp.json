
{
  "format_version": "1.10.0",
  "minecraft:attachable": {
    "description": {
      "identifier": "addon:pkp",
      "materials": {
        "default": "entity_alphatest"
      },
      "textures": {
        "default": "textures/guns/ussr/pkp"
      },
      "geometry": {
        "default":  "geometry.pkp"
      },
      "scripts": {
        "pre_animation": [
           "v.main_hand = c.item_slot == 'main_hand';",
           "v.guns = c.item_slot == 'main_hand';",
           "v.pkp = c.item_slot == 'main_hand';",
           "v.fire = q.main_hand_item_use_duration > 0.0f;"
        ],
        "animate": [
          {"idle_controller": "c.is_first_person"},
          {"pkp_item": "c.is_first_person"},
          {"pkp_controller": "c.is_first_person"},
          {"pkp_controller_third": "!c.is_first_person && !query.is_riding"},
          {"pkp_controller_sneak": "!c.is_first_person && query.is_riding"},
          {"pkp_fire_controller": "variable.pkm"}

        ]
      },
      "animations": {
        "idle_controller": "controller.animation.gun_idle",
        "idle": "animation.gun_idle",
        "idle2": "animation.gun_idle2",
        "pkp_controller": "controller.animation.pkp",
        "pkp_controller_sneak": "controller.animation.pkp_sneak",
        "pkp_sneak": "animation.pkp_sneak",
        "pkp_reload_sneak": "animation.pkp_reload_sneak",
        "pkp_reload2_sneak": "animation.pkp_reload2_sneak",
        "pkp_controller_third": "controller.animation.pkp_third",
        "pkp_fire_controller": "controller.animation.pkp_fire",
        "pkp_item_third": "animation.pkp_item_third",
        "shoot": "animation.pkp_shoot",
        "pkp_aim": "animation.aim_item_pkp",
        "pkp_aim_third": "animation.pkp_aim_third",
        "pkp_sprint_third": "animation.pkp_sprint_third",
        "pkp_item": "animation.pkp_item",
        "pkp_reload": "animation.pkp_reload",
        "pkp_reload2": "animation.pkp_reload2",
        "pkp_reload_third": "animation.pkp_reload_third",
        "pkp_reload2_third": "animation.pkp_reload2_third",
        "gun_third": "animation.gun_third_pkp",
        "pkp_third": "animation.pkp_item_third"
      },
      "render_controllers": [ 
         "controller.render.pkp" ]
    }
  }
}