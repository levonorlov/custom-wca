
{
  "format_version": "1.10.0",
  "minecraft:attachable": {
    "description": {
      "identifier": "addon:rpk",
      "materials": {
        "default": "entity_alphatest"
      },
      "textures": {
        "default": "textures/guns/ussr/rpk"
      },
      "geometry": {
        "default":  "geometry.rpk"
      },
      "scripts": {
        "pre_animation": [
           "v.main_hand = c.item_slot == 'main_hand';",
           "v.rpk = c.item_slot == 'main_hand';",
           "v.fire = q.main_hand_item_use_duration > 0.0f;"
        ],
        "animate": [
          {"rpk_controller": "c.is_first_person"},
          {"rpk_fire_controller": "variable.rpk && variable.is_first_person"}

        ]
      },
      "animations": {
        "rpk_controller": "controller.animation.rpk",
        "rpk_reload": "animation.rpk_reload_item"
      },
      "render_controllers": [ "controller.render.crossbow" ]
    }
  }
}