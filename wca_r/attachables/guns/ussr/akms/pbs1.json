
{
  "format_version": "1.10.0",
  "minecraft:attachable": {
    "description": {
      "identifier": "addon:akms_pbs1",
      "materials": {
        "default": "entity_alphatest",
        "pbs": "spider"
      },
      "textures": {
        "default": "textures/guns/ussr/akms",
        "pbs": "textures/guns/pbs1"
      },
      "geometry": {
        "default":  "geometry.akms",
        "pbs":  "geometry.pbs1"
      },
      "scripts": {
        "pre_animation": [
           "v.main_hand = c.item_slot == 'main_hand';",
           "v.akms = c.item_slot == 'main_hand';",
           "v.fire = q.main_hand_item_use_duration > 0.0f;"
        ],
        "animate": [
          {"akms_controller": "c.is_first_person"},
          {"akms_fire_controller": "variable.akms && variable.is_first_person"}

        ]
      },
      "animations": {
        "akms_controller": "controller.animation.akms",
        "akms_reload": "animation.akms_reload_item"
      },
      "render_controllers": [ "controller.render.crossbow","controller.render.pbs" ]
    }
  }
}