
{
  "format_version": "1.10.0",
  "minecraft:attachable": {
    "description": {
      "identifier": "addon:rpoa",
      "materials": {
        "default": "entity_alphatest"
      },
      "textures": {
        "default": "textures/guns/ussr/rpoa"
      },
      "geometry": {
        "default":  "geometry.rpoa"
      },
      "scripts": {
        "pre_animation": [
           "v.main_hand = c.item_slot == 'main_hand';",
           "v.rpoa = c.item_slot == 'main_hand';",
           "v.fire = q.main_hand_item_use_duration > 0.0f;"
        ],
        "animate": [
          {"rpoa_controller": "c.is_first_person"},
          "rpoa_empty2",
          {"rpoa_fire_controller": "variable.rpoa && variable.is_first_person"}

        ]
      },
      "animations": {
        "rpoa_controller": "controller.animation.rpoa",
        "rpoa_fire_controller": "controller.animation.rpoa_fire",
        "rpoa_shoot": "animation.rpoa_shoot",
        "rpoa_empty2": "animation.rpoa_empty2",
        "rpoa_reload": "animation.rpoa_reload_item",
        "rpoa_aim": "animation.rpoa_aim_item"
      },
      "render_controllers": [ "controller.render.crossbow" ]
    }
  }
}