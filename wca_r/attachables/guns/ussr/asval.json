
{
  "format_version": "1.10.0",
  "minecraft:attachable": {
    "description": {
      "identifier": "addon:asval",
      "materials": {
        "default": "entity_alphatest"
      },
      "textures": {
        "default": "textures/guns/ussr/asval"
      },
      "geometry": {
        "default":  "geometry.asval"
      },
      "scripts": {
        "pre_animation": [
           "v.main_hand = c.item_slot == 'main_hand';",
           "v.asval = c.item_slot == 'main_hand';",
           "v.fire = q.main_hand_item_use_duration > 0.0f;"
        ],
        "animate": [
          {"asval_controller": "c.is_first_person"},
          {"asval_fire_controller": "variable.asval && variable.is_first_person"}

        ]
      },
      "animations": {
        "asval_controller": "controller.animation.asval",
        "asval_fire_controller": "controller.animation.asval_fire",
        "asval_shoot": "animation.asval_shoot",
        "asval_reload": "animation.asval_reload_item"
      },
      "render_controllers": [ "controller.render.crossbow" ]
    }
  }
}