
{
  "format_version": "1.10.0",
  "minecraft:attachable": {
    "description": {
      "identifier": "addon:rgd5",
      "materials": {
        "default": "entity_alphatest",
        "slime": "slime_outer"
      },
      "textures": {
        "default": "textures/entity/rgd5"
      },
      "geometry": {
        "default":  "geometry.rgd5"
      },
      "scripts": {
        "pre_animation": [
           "v.main_hand = c.item_slot == 'main_hand';",
           "v.rgd5 = c.item_slot == 'main_hand';",
           "v.fire = q.main_hand_item_use_duration > 0.0f;"
        ],
        "animate": [
          {"rgd5_controller": "c.is_first_person"},
          {"rgd5_controller_third": "!c.is_first_person"}

        ]
      },
      "animations": {
        "rgd5_controller": "controller.animation.rgd5",
        "rgd5": "animation.rgd5",
        "crawl": "controller.animation.crawl",
        "crawl1": "animation.crawl1",
        "crawl2": "animation.crawl2",
        "rgd5_use": "animation.rgd5_use",
        "rgd5_unuse": "animation.rgd5_unuse",
				"rgd5_controller_third": "controller.animation.rgd5_third",
        "rgd5_third": "animation.rgd5_third",
        "rgd5_use_third": "animation.rgd5_use_third",
        "rgd5_unuse_third": "animation.rgd5_unuse_third"
      },
      "render_controllers": [ 
        "controller.render.crossbow"
    ]
    }
  }
}